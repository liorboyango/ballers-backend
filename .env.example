# ─────────────────────────────────────────────
# Ballers Backend - Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# Firebase Firestore (required)
# Paste the contents of your service-account JSON key as a single line, or
# base64-encode it (e.g., `base64 -i service-account.json`). Both forms work.
# Create one in the Firebase console: Project Settings → Service Accounts → Generate new private key.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Firebase Storage bucket for product images (optional)
# Defaults to <project_id>.appspot.com if unset.
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# JWT Authentication (required)
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Gemini (Google AI Studio) — used to auto-generate product shirt images
# when no image file is uploaded with the product.
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optional override; defaults to the "nano banana" image model.
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# ─────────────────────────────────────────────
# Rapyd Payments (required for checkout)
# ─────────────────────────────────────────────
# Get your keys from the Rapyd Client Portal → Developers → Credential Details:
#   https://dashboard.rapyd.net/sandbox/dashboard/developers/api-keys
# Use the SANDBOX keys for development/testing and PRODUCTION keys for live.
# Both must come from the SAME environment (sandbox or production) — mixing
# keys across environments will produce signature errors.
RAPYD_ACCESS_KEY=your_rapyd_access_key_here
RAPYD_SECRET_KEY=your_rapyd_secret_key_here

# Rapyd Webhook Secret (required for verifying webhook events)
# Configure your webhook endpoint in the Rapyd dashboard at:
#   Developers → Webhooks → New Webhook
#   URL: https://<your-backend-domain>/api/rapyd/webhook
# After creating it, copy the "verification key" / signing secret here.
RAPYD_WEBHOOK_SECRET=your_rapyd_webhook_secret_here

# Rapyd Webhook URL (required for verifying webhook signatures)
# Must match the EXACT public URL configured on the webhook in the Rapyd
# dashboard — Rapyd includes the URL in the HMAC payload, so any mismatch
# (trailing slash, http vs https, port, etc.) will cause signature
# verification to fail.
RAPYD_WEBHOOK_URL=https://your-backend-domain/api/rapyd/webhook

# Rapyd API base URL (optional override)
# Defaults to:
#   https://sandboxapi.rapyd.net  when NODE_ENV is not 'production'
#   https://api.rapyd.net         when NODE_ENV === 'production'
# Set this only if you need to point at a different environment.
# RAPYD_API_URL=https://sandboxapi.rapyd.net

# Logging
LOG_LEVEL=debug
