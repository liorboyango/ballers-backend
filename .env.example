# ─────────────────────────────────────────────────────────────────────────────
# Ballers Backend - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
# Port the Express server listens on
PORT=5000

# Application environment: development | production | test
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
# MongoDB connection string
# Local:  mongodb://localhost:27017/ballers
# Atlas:  mongodb+srv://<username>:<password>@<cluster>.mongodb.net/ballers?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/ballers

# ── Authentication ────────────────────────────────────────────────────────────
# Secret key for signing JWT tokens
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT token expiry duration (e.g., 24h, 7d, 1h)
JWT_EXPIRES_IN=24h

# ── CORS ─────────────────────────────────────────────────────────────────────
# Frontend application URL (used for CORS whitelist)
FRONTEND_URL=http://localhost:3000

# ── Logging ──────────────────────────────────────────────────────────────────
# Winston log level: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=debug
