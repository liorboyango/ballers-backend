# ─────────────────────────────────────────────
# Ballers Backend - Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# Firebase Firestore (required)
# Paste the contents of your service-account JSON key as a single line, or
# base64-encode it (e.g., `base64 -i service-account.json`). Both forms work.
# Create one in the Firebase console: Project Settings → Service Accounts → Generate new private key.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Firebase Storage bucket for product images (optional)
# Defaults to <project_id>.appspot.com if unset.
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# JWT Authentication (required)
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Gemini (Google AI Studio) — used to auto-generate product shirt images
# when no image file is uploaded with the product.
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optional override; defaults to the "nano banana" image model.
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# ─────────────────────────────────────────────
# Airwallex Payments (required for checkout)
# ─────────────────────────────────────────────
# Get your credentials from the Airwallex dashboard → Account settings → API keys:
#   https://www.airwallex.com/app/account/apiKeys
# Use the DEMO credentials for development/testing and LIVE credentials for
# production. The backend exchanges these for a short-lived bearer token.
AIRWALLEX_CLIENT_ID=your_airwallex_client_id_here
AIRWALLEX_API_KEY=your_airwallex_api_key_here

# Airwallex Webhook Secret (required for verifying webhook events)
# Configure your webhook endpoint in the Airwallex dashboard at:
#   Developers → Webhooks → Add webhook
#   URL: https://<your-backend-domain>/api/airwallex/webhook
# After creating it, copy the webhook "secret key" here. Airwallex signs each
# delivery with hex(hmac_sha256(secret, timestamp + body)).
AIRWALLEX_WEBHOOK_SECRET=your_airwallex_webhook_secret_here

# Airwallex API base URL (optional override)
# Defaults to:
#   https://api-demo.airwallex.com  when NODE_ENV is not 'production'
#   https://api.airwallex.com       when NODE_ENV === 'production'
# Set this only if you need to point at a different environment.
# AIRWALLEX_API_URL=https://api-demo.airwallex.com

# Logging
LOG_LEVEL=debug
